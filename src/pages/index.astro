    <button
      type="button"
      id="back-to-top"
      class="back-to-top"
      aria-label="回到頁面頂部"
      title="回到頁面頂部"
      hidden
    >
      <svg class="back-to-top__icon" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      // Mobile nav menu
      const navMenuToggle = document.getElementById("nav-menu-toggle");
      const navPanel = document.getElementById("mobile-nav-panel");

      function setNavMenuOpen(open: boolean) {
        if (!navMenuToggle || !navPanel) return;
        navPanel.hidden = !open;
        navMenuToggle.setAttribute("aria-expanded", open ? "true" : "false");
        navMenuToggle.setAttribute("aria-label", open ? "關閉選單" : "開啟選單");
        navMenuToggle.classList.toggle("nav-menu-btn--open", open);
      }

      navMenuToggle?.addEventListener("click", () => {
        const willOpen = navPanel?.hidden ?? true;
        setNavMenuOpen(willOpen);
      });

      navPanel?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => setNavMenuOpen(false));
      });

      window.matchMedia("(min-width: 768px)").addEventListener("change", (e) => {
        if (e.matches) setNavMenuOpen(false);
      });

      // Back to top
      const backToTop = document.getElementById("back-to-top");
      const backToTopThreshold = 400;

      function updateBackToTop() {
        if (!backToTop) return;
        const show = window.scrollY > backToTopThreshold;
        backToTop.hidden = !show;
        backToTop.classList.toggle("back-to-top--visible", show);
      }

      updateBackToTop();
      window.addEventListener("scroll", updateBackToTop, { passive: true });

      backToTop?.addEventListener("click", () => {
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
      });

      // Menu carousel (mobile/tablet: 2-up peek · desktop: 3 columns)
      const menuTrack = document.getElementById("menu-carousel-track");
      const menuViewport = document.getElementById("menu-carousel-viewport");
      const menuSlides = menuTrack?.querySelectorAll<HTMLElement>(".menu-carousel-slide");
      const menuDots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");
      let menuSlideIndex = 0;
      let carouselPeekNudged = false;
      let carouselHasInteracted = false;

      const desktopCarouselMq = window.matchMedia("(min-width: 1024px)");
      const tabletCarouselMq = window.matchMedia("(min-width: 640px) and (max-width: 1023px)");

      const carouselHints = [
        document.getElementById("menu-carousel-hint-desktop"),
      ].filter((el): el is HTMLElement => el instanceof HTMLElement);

      function dismissCarouselHints() {
        carouselHints.forEach((el) => el.classList.add("carousel-hint--dismissed"));
      }

      function markCarouselInteracted() {
        if (carouselHasInteracted || !menuViewport) return;
        carouselHasInteracted = true;
        menuViewport.classList.add("has-interacted");
      }

      function runCarouselPeekNudge() {
        if (carouselPeekNudged || carouselHasInteracted || !menuTrack) return;
        if (desktopCarouselMq.matches) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        carouselPeekNudged = true;
        const start = menuTrack.scrollLeft;
        const nudge = Math.min(44, menuTrack.clientWidth * 0.11);

        menuTrack.scrollTo({ left: start + nudge, behavior: "smooth" });
        window.setTimeout(() => {
          menuTrack.scrollTo({ left: start, behavior: "smooth" });
        }, 700);
      }

      const menuProgressCurrent = document.getElementById("menu-carousel-progress-current");

      function updateCarouselScrollState() {
        if (!menuTrack || !menuViewport) return;

        const { scrollLeft, scrollWidth, clientWidth } = menuTrack;
        const atStart = scrollLeft <= 8;
        const atEnd = scrollLeft + clientWidth >= scrollWidth - 8;

        menuViewport.classList.toggle("is-at-start", atStart);
        menuViewport.classList.toggle("is-at-end", atEnd);

        if (menuProgressCurrent) {
          menuProgressCurrent.textContent = String(menuSlideIndex + 1);
        }
      }

      function getSlidesPerView() {
        if (desktopCarouselMq.matches) return 3;
        if (tabletCarouselMq.matches) return 2;
        return 1;
      }

      function updateActiveDots() {
        menuDots.forEach((dot, i) => {
          const active = i === menuSlideIndex;
          dot.classList.toggle("is-active", active);
          dot.setAttribute("aria-selected", active ? "true" : "false");
        });
      }

      function syncMenuIndexFromScroll() {
        if (!menuSlides?.length || !menuTrack) return;
        const trackRect = menuTrack.getBoundingClientRect();
        const trackAnchor = trackRect.left + trackRect.width * 0.2;
        let closestIdx = menuSlideIndex;
        let closestDist = Infinity;

        menuSlides.forEach((slide, i) => {
          const rect = slide.getBoundingClientRect();
          const slideAnchor = rect.left;
          const dist = Math.abs(slideAnchor - trackAnchor);
          if (dist < closestDist) {
            closestDist = dist;
            closestIdx = i;
          }
        });

        menuSlideIndex = closestIdx;
      }

      function goToMenuSlide(index: number) {
        if (!menuSlides?.length || !menuTrack) return;
        const maxIndex = menuSlides.length - 1;
        const perView = getSlidesPerView();
        const maxStart = Math.max(0, maxIndex - perView + 1);
        menuSlideIndex = Math.max(0, Math.min(index, maxStart));

        const target = menuSlides[menuSlideIndex];

        target?.scrollIntoView({
          behavior: "smooth",
          inline: "start",
          block: "nearest",
        });
        updateActiveDots();
        updateCarouselScrollState();
        dismissCarouselHints();
      }

      function stepMenuCarousel(direction: number) {
        goToMenuSlide(menuSlideIndex + direction * getSlidesPerView());
      }

      document.getElementById("menu-carousel-prev")?.addEventListener("click", () => {
        markCarouselInteracted();
        stepMenuCarousel(-1);
      });
      document.getElementById("menu-carousel-next")?.addEventListener("click", () => {
        markCarouselInteracted();
        stepMenuCarousel(1);
      });
      menuDots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
          markCarouselInteracted();
          goToMenuSlide(i);
        });
      });

      const syncCarouselLayout = () => {
        goToMenuSlide(menuSlideIndex);
        updateCarouselScrollState();
      };
      desktopCarouselMq.addEventListener("change", syncCarouselLayout);
      tabletCarouselMq.addEventListener("change", syncCarouselLayout);

      if (menuTrack && menuSlides?.length && "IntersectionObserver" in window) {
        const slideObserver = new IntersectionObserver(
          (entries) => {
            let bestIdx = menuSlideIndex;
            let bestRatio = 0;
            entries.forEach((entry) => {
              if (entry.isIntersecting && entry.intersectionRatio > bestRatio) {
                bestRatio = entry.intersectionRatio;
                const idx = Number((entry.target as HTMLElement).dataset.slideIndex);
                if (!Number.isNaN(idx)) bestIdx = idx;
              }
            });
            if (bestRatio > 0.4 && bestIdx !== menuSlideIndex) {
              menuSlideIndex = bestIdx;
              updateActiveDots();
              updateCarouselScrollState();
            }
          },
          { root: menuViewport ?? menuTrack, threshold: [0.4, 0.55, 0.7] }
        );
        menuSlides.forEach((slide) => slideObserver.observe(slide));
      }

      // Desktop: drag within viewport to scroll carousel (horizontal intent only)
      if (menuViewport && menuTrack) {
        let isPointerDragging = false;
        let pointerStartX = 0;
        let pointerStartY = 0;
        let pointerStartScroll = 0;
        let pointerDidDrag = false;
        let dragAxis: "x" | "y" | null = null;

        menuViewport.addEventListener("mousedown", (event) => {
          if (!desktopCarouselMq.matches || event.button !== 0) return;
          const target = event.target as HTMLElement;
          if (target.closest("button, a")) return;

          isPointerDragging = true;
          pointerDidDrag = false;
          dragAxis = null;
          pointerStartX = event.pageX;
          pointerStartY = event.pageY;
          pointerStartScroll = menuTrack.scrollLeft;
        });

        window.addEventListener("mousemove", (event) => {
          if (!isPointerDragging) return;

          const deltaX = event.pageX - pointerStartX;
          const deltaY = event.pageY - pointerStartY;

          if (dragAxis === null) {
            if (Math.abs(deltaX) < 6 && Math.abs(deltaY) < 6) return;
            dragAxis = Math.abs(deltaX) > Math.abs(deltaY) ? "x" : "y";
            if (dragAxis === "y") {
              isPointerDragging = false;
              return;
            }
            menuViewport.classList.add("menu-carousel-viewport--dragging");
          }

          if (dragAxis !== "x") return;

          if (Math.abs(deltaX) > 4) pointerDidDrag = true;
          menuTrack.scrollLeft = pointerStartScroll - deltaX;
        });

        window.addEventListener("mouseup", (event) => {
          const wasHorizontal = dragAxis === "x" && pointerDidDrag;
          const delta = event.pageX - pointerStartX;

          isPointerDragging = false;
          dragAxis = null;
          menuViewport.classList.remove("menu-carousel-viewport--dragging");

          if (!desktopCarouselMq.matches || !wasHorizontal) {
            pointerDidDrag = false;
            return;
          }

          syncMenuIndexFromScroll();

          if (Math.abs(delta) > 48) {
            goToMenuSlide(menuSlideIndex + (delta > 0 ? -1 : 1));
          } else {
            goToMenuSlide(menuSlideIndex);
          }

          pointerDidDrag = false;
        });

        menuViewport.addEventListener(
          "click",
          (event) => {
            if (!pointerDidDrag) return;
            event.preventDefault();
            event.stopPropagation();
            pointerDidDrag = false;
          },
          true,
        );
      }

      menuTrack?.addEventListener(
        "scroll",
        () => {
          syncMenuIndexFromScroll();
          updateActiveDots();
          updateCarouselScrollState();
          if (menuTrack && menuTrack.scrollLeft > 8) {
            markCarouselInteracted();
          }
        },
        { passive: true },
      );

      const menuSection = document.getElementById("menu");
      if (menuSection && menuTrack && "IntersectionObserver" in window) {
        const nudgeObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting && entry.intersectionRatio >= 0.3) {
                window.setTimeout(runCarouselPeekNudge, 1000);
                nudgeObserver.disconnect();
              }
            });
          },
          { threshold: [0.3, 0.5] },
        );
        nudgeObserver.observe(menuSection);
      }

      updateCarouselScrollState();
      window.addEventListener("resize", updateCarouselScrollState, { passive: true });

    </script>
	</body>
</html>
