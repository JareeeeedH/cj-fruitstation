---
import "../styles/global.css";

const imgHero = "/juice-1.webp";
const imgStorefront = "/homePhoto-3.webp";
const imgMenuProduct = "/juice-2.webp";

const brandName = "旗津蔬果茶飲";
const brandTagline = "現點現打 · 真水果，現場做";
const brandSlogan = "卡你牙的不只是剛剛的食物，也會是果肉。";

const siteUrl = Astro.site?.href ?? Astro.url.origin;
const ogImage = new URL(imgStorefront, siteUrl).href;

const siteTitle = `旗津必吃、旗津隱藏版美食｜旗津果汁 — ${brandName}`;
const siteDescription =
  `${brandName}：旗津必吃、旗津隱藏版美食名單裡常被忽略的現打果汁老店，旗津果汁現場點、現做。在地20餘年，中洲三路641，渡輪站步行約6分鐘、海科大斜對面約1分鐘。平日10:00–19:00；週末營業至下午（可能更早），來電 0987-553-799 確認。`;

const seoKeywords =
  "旗津必吃,旗津隱藏版美食,旗津果汁,旗津美食,旗津一日遊推薦,高雄現打果汁,旗津冰沙,旗津現打果汁,中洲三路,旗津渡輪站,海洋科技大學,木瓜牛奶,芒果冰沙";

const storePhone = "0987-553-799";
const storePhoneHref = "tel:+886987553799";

const businessHours = {
  weekday: "週一至週五 10:00－19:00",
  weekend: "週六、週日 10:00－16:00（亦可能更早）",
  note:
    "週末僅營業至下午，亦有可能更早打烊——週末沒有上班族與學生，闆娘要早點休息。建議前來的旅客可先來電確認。",
  phone: storePhone,
  phoneHref: storePhoneHref,
};

const heroPoints = [
  { mark: "📍", text: "在地經營、用料實在。" },
  { mark: "👤", text: "當地居民與學生，每天來這補一杯。" },
  { mark: "✓", text: "中洲三路641，渡輪站步行約 6 分鐘、海科大斜對面。" },
];

const ownerStories = [
  {
    title: "闆娘日常：跟果農較真",
    text: "雨季或耕作不好，水果品質差，果農還說「幫忙銷貨，打果汁沒關係吧」。闆娘當場嗆：「你賣這什麼垃圾給我啊！」——為此沒少跟果農吵架。",
  },
  {
    title: "闆娘堅持：塑化劑風波",
    text: "想起塑化劑風波那段日子，大家不敢喝飲料，瞬間湧入大批想喝果汁的客人。闆娘堅持現點現打、真水果不打折——二十年走下來，就希望大家喝得安心，也喝得健康。",
  },
];

const menuItems = [
  {
    name: "石蓮花奇異果",
    nameEn: "Cactus Pear & Kiwi",
    image: "/menu-cactus-kiwi.webp",
    price: 85,
    tag: "招牌推薦",
    tagColor: "bg-mango-500",
    intro: "富含維他命C，酸酸甜甜清涼順口，退火消暑走累首選。",
    taste: { sour: 58, sweet: 42 },
  },
  {
    name: "蔓越莓汁",
    nameEn: "Antioxidant Cranberry",
    image: "/menu-cranberry.webp",
    price: 80,
    tag: "老店研發",
    tagColor: "bg-mint-500",
    intro: "現榨酸甜，抗氧化系飲品，內行女生常來的秘密杯。",
    taste: { sour: 72, sweet: 28 },
  },
  {
    name: "芒果冰沙",
    nameEn: "Mango Smoothie",
    image: "/menu-mango-smoothie.webp",
    price: 75,
    tag: "20年經典",
    tagColor: "bg-mango-400",
    intro: "濃郁香甜沁涼順口，不膩解熱，老街逛完最想來一杯。",
    taste: { sour: 18, sweet: 82 },
  },
  {
    name: "紅龍果牛奶",
    nameEn: "Dragon Fruit Milk",
    image: "/menu-dragon-fruit-milk.webp",
    price: 70,
    tag: "在地最愛",
    tagColor: "bg-mint-600",
    intro: "甜菜紅素抗氧化，粉嫩順口綿密，午後補元氣好選擇。",
    taste: { sour: 22, sweet: 78 },
  },
  {
    name: "綜合蔬果汁",
    nameEn: "Mixed Veggie Juice",
    image: "/menu-mixed-veggie.webp",
    price: 65,
    tag: "健康首選",
    tagColor: "bg-mint-400",
    intro: "當季現榨高膳食纖維，清甜不生澀，顧健康內行都愛點。",
    taste: { sour: 45, sweet: 55 },
  },
  {
    name: "經典木瓜牛奶",
    nameEn: "Classic Papaya Milk",
    image: "/menu-papaya-milk.webp",
    price: 65,
    tag: "20年經典",
    tagColor: "bg-mango-500",
    intro: "濃稠順口不死甜，天然酵素助消化，老客二十年不離手。",
    taste: { sour: 12, sweet: 88 },
  },
  {
    name: "葡萄多多",
    nameEn: "Grape Duoduo",
    image: "/menu-grape-duoduo.webp",
    price: 70,
    tag: "人氣必點",
    tagColor: "bg-mint-500",
    intro: "酸甜微氣泡感，沁涼解暑順口，夏天走熱最想再來杯。",
    taste: { sour: 42, sweet: 58 },
  },
  {
    name: "綠豆沙牛奶",
    nameEn: "Mung Bean Milk",
    image: "/menu-mung-bean-milk.webp",
    price: 65,
    tag: "南部經典",
    tagColor: "bg-mango-400",
    intro: "綿密砂感消暑退火，順口不膩，南部老客說最實在的一杯。",
    taste: { sour: 15, sweet: 85 },
  },
];

const attractions = [
  {
    name: "旗津天后宮",
    emoji: "🛕",
    keywords: "旗津一日遊推薦 · 廟前老街",
    desc: "拜完媽祖、逛廟前路老街，海鮮小吃一輪下來嘴巴又鹹又渴。<strong>旗津一日遊推薦</strong>動線多半會經過這帶，順路來杯現打果汁解膩，比便利商店瓶裝的實在。",
  },
  {
    name: "高雄燈塔",
    emoji: "🗼",
    keywords: "旗津一日遊推薦 · 解渴補給站",
    desc: "爬完燈塔下來，海風吹得口很渴？<strong>旗津一日遊推薦</strong>路線其實會經過這段，但很多人走過去不知道。順路買杯<strong>高雄現打果汁</strong>補水，內行才會停。",
  },
  {
    name: "旗津老街",
    emoji: "🏮",
    keywords: "旗津美食 · 旗津蔬果茶飲",
    desc: `老街<strong>旗津美食</strong>、<strong>旗津小吃</strong>吃一圈，吃飽後很適合來杯現打果汁解膩。嘴巴鹹了、走累了也剛好——觀光動線會經過，但攻略很少寫，<strong>在地內行才知道</strong>的<strong>${brandName}</strong>。`,
  },
  {
    name: "彩虹教堂",
    emoji: "⛪",
    keywords: "旗津一日遊推薦 · 打卡後歇腳",
    desc: "彩虹教堂拍完照，太陽正猛。這段<strong>旗津一日遊推薦</strong>動線你會走過，但不一定會注意到我們——買杯芒果冰沙邊走邊喝，比便利商店瓶裝的實在。",
  },
  {
    name: "風車公園",
    emoji: "🌬️",
    keywords: "旗津美食 · 親子同遊",
    desc: "帶小孩跑風車公園，大人小孩都渴。綜合果汁現打現做，真水果給孩子喝也安心。旗津親子<strong>旗津美食</strong>行程，這杯可以排進去。",
  },
  {
    name: "旗後砲台",
    emoji: "🏰",
    keywords: "旗津一日遊推薦 · 走累就買",
    desc: "砲台上下爬，腿酸口也乾。走下來買杯<strong>高雄現打果汁</strong>歇個腳，20年老店就在附近。很多<strong>旗津一日遊推薦</strong>攻略後來才補寫：路過不知道，走了才後悔沒買。",
  },
];

const articles = [
  {
    title: "高雄「鳳荔季」開跑　行銷在地農特產",
    source: "中央社 CNA",
    date: "2026-05-30",
    excerpt:
      "2026 高雄鳳荔季於大樹區農會姑山倉庫登場，推廣玉荷包荔枝、金鑽鳳梨；市府指大樹有「玉荷包故鄉」美名，金鑽鳳梨產期僅約 2 至 3 週，把握當季選購。",
    url: "https://www.cna.com.tw/news/aloc/202605300111.aspx",
    category: "高雄農業",
  },
  {
    title: "5月起月月有水果　高雄夏祭新鮮市開跑",
    source: "自由時報",
    date: "2026-05-27",
    excerpt:
      "2026 高雄夏祭新鮮市 5 月至 9 月串聯鳳荔、金煌芒果、龍眼蜂蜜、香蕉等活動；並宣布學校營養午餐將採用高雄在地水果，縮短碳足跡、推動食農教育。",
    url: "https://news.ltn.com.tw/news/life/breakingnews/5451091",
    category: "產季活動",
  },
  {
    title: "高溫少雨催熟　玉荷包荔枝提早上市",
    source: "自由時報",
    date: "2026-05-21",
    excerpt:
      "大樹玉荷包因高溫少雨提早進入盛產，產季可能較往年提早結束；高雄玉荷包種植面積與產量全國第一，5 月 30、31 日鳳荔季活動於姑山倉庫登場。",
    url: "https://news.ltn.com.tw/news/life/breakingnews/5445032",
    category: "產季報導",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "JuiceBar",
  name: brandName,
  alternateName: ["旗津必吃", "旗津隱藏版美食", "旗津果汁"],
  description: siteDescription,
  image: ogImage,
  address: {
    "@type": "PostalAddress",
    streetAddress: "中洲三路641",
    addressLocality: "旗津區",
    addressRegion: "高雄市",
    postalCode: "805",
    addressCountry: "TW",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 22.6128,
    longitude: 120.2842,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "10:00",
      closes: "19:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday", "Sunday"],
      opens: "10:00",
      closes: "16:00",
    },
  ],
  telephone: "+886987553799",
  priceRange: "$$",
  servesCuisine: "Fresh Juice, Smoothie",
  url: siteUrl,
};

---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="keywords" content={seoKeywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={new URL(Astro.url.pathname, siteUrl).href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${brandName} — 旗津必吃現打果汁`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="overflow-x-hidden text-gray-800 antialiased">
    <!-- ========== Header / Nav ========== -->
    <header class="glass-nav sticky top-0 z-40">
      <nav
        class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6"
        aria-label="主要導覽"
      >
        <a href="/" class="group flex items-center gap-2">
          <span
            class="logo-glow flex h-9 w-9 items-center justify-center rounded-xl text-lg text-white"
            aria-hidden="true"
          >🍊</span>
          <div class="leading-tight">
            <span class="block text-sm font-extrabold text-mango-600 sm:text-base">
              {brandName}
            </span>
            <span class="block text-[10px] font-medium text-gray-500 sm:text-xs">
              {brandTagline}
            </span>
          </div>
        </a>

        <ul class="hidden items-center gap-1 md:flex">
          <li>
            <a
              href="#menu"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >果汁好物</a>
          </li>
          <li>
            <a
              href="#about"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >關於蔬果茶飲</a>
          </li>
          <li>
            <a
              href="#location"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >店面位置</a>
          </li>
          <li>
            <a
              href="#guide"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >觀光導覽</a>
          </li>
          <li>
            <a
              href="#reading"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >水果讀物</a>
          </li>
        </ul>

        <a
          href="#menu"
          class="btn-glow rounded-full bg-mango-500 px-4 py-2 text-xs font-bold text-white shadow-md shadow-mango-500/30 hover:bg-mango-600 sm:text-sm"
        >
          推薦飲品
        </a>
      </nav>

      <!-- Mobile nav -->
      <div class="border-t border-gray-100 md:hidden">
        <ul class="flex overflow-x-auto px-4 py-2 text-xs font-medium whitespace-nowrap">
          <li><a href="#menu" class="mr-4 text-gray-600">果汁好物</a></li>
          <li><a href="#about" class="mr-4 text-gray-600">關於蔬果茶飲</a></li>
          <li><a href="#location" class="mr-4 text-gray-600">店面位置</a></li>
          <li><a href="#guide" class="mr-4 text-gray-600">觀光導覽</a></li>
          <li><a href="#reading" class="text-gray-600">水果讀物</a></li>
        </ul>
      </div>
    </header>

    <main>
      <!-- ========== Hero ========== -->
      <section
        class="hero-mesh relative overflow-hidden"
        aria-label="首頁橫幅"
      >
        <!-- Aurora + bubbles -->
        <div class="hero-aurora" aria-hidden="true"></div>
        <div class="bubble-field absolute inset-0" aria-hidden="true">
          <span class="bubble bubble--mango" style="--dur:9s;--delay:0s;--opacity:0.5;width:88px;height:88px;top:12%;left:6%;"></span>
          <span class="bubble bubble--mint" style="--dur:11s;--delay:1s;--opacity:0.45;width:56px;height:56px;top:28%;left:18%;"></span>
          <span class="bubble" style="--dur:8s;--delay:2s;--opacity:0.4;width:120px;height:120px;top:55%;left:4%;"></span>
          <span class="bubble bubble--mango" style="--dur:10s;--delay:0.5s;--opacity:0.55;width:72px;height:72px;top:18%;right:12%;"></span>
          <span class="bubble bubble--mint" style="--dur:12s;--delay:1.5s;--opacity:0.42;width:96px;height:96px;top:62%;right:8%;"></span>
          <span class="bubble" style="--dur:7s;--delay:3s;--opacity:0.35;width:44px;height:44px;top:78%;left:42%;"></span>
          <span class="bubble bubble--mango" style="--dur:9s;--delay:2.5s;--opacity:0.38;width:64px;height:64px;top:8%;left:48%;"></span>
        </div>

        <div class="hero-inner relative mx-auto max-w-6xl px-4 sm:px-6">
          <div class="grid items-center gap-8 lg:grid-cols-2">
            <div>
              <span
                class="tech-pill mb-4 inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-semibold text-mint-600"
              >
                🌴 在地經營20餘年 · 內行人的營養補充站
              </span>
              <h1 class="hero-headline">
                <span class="hero-brand-wrap">
                  <strong class="hero-brand-title">{brandName}</strong>
                  <span class="hero-brand-accent" aria-hidden="true"></span>
                </span>
                <span class="gradient-heading hero-tagline">{brandTagline}</span>
              </h1>
              <ul class="hero-points max-w-lg" aria-label="店家特色">
                {
                  heroPoints.map((point) => (
                    <li class="hero-points__item">
                      <span class="hero-points__mark" aria-hidden="true">{point.mark}</span>
                      <span class="hero-points__text">{point.text}</span>
                    </li>
                  ))
                }
              </ul>
              <div class="mt-8 flex flex-wrap gap-3">
                <a
                  href="#menu"
                  class="btn-glow inline-flex items-center gap-2 rounded-full bg-mango-500 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-mango-500/30 hover:bg-mango-600"
                >
                  看推薦飲品
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <a
                  href="#location"
                  class="inline-flex items-center gap-2 rounded-full border-2 border-gray-200 bg-white px-6 py-3 text-sm font-bold text-gray-700 transition hover:border-mint-400 hover:text-mint-600"
                >
                  店怎麼走
                </a>
              </div>
            </div>

            <div>
              <div class="relative aspect-[4/3] overflow-hidden rounded-3xl shadow-lg shadow-mango-500/10 ring-1 ring-black/5">
                <img
                  src={imgHero}
                  alt={`${brandName}現打鮮果汁`}
                  class="h-full w-full object-cover"
                  width={800}
                  height={600}
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== 果汁好物（banner 下方） ========== -->
      <section id="menu" class="section-bg section-bg-menu scroll-mt-20 section-after-hero">
        <div class="tech-grid-layer" aria-hidden="true"></div>
        <div class="section-inner mx-auto max-w-6xl px-4 sm:px-6">
          <div class="mb-6 text-left">
            <span class="section-badge tech-badge">Fresh Menu</span>
            <h2 class="section-title-tech mt-3">果汁好物</h2>
            <div class="section-accent-line"></div>
            <div class="menu-intro mt-3 max-w-2xl">
              <p>推薦從這八杯認識起，現場點、現打現做。</p>
              <p>
                濃郁的口感、在嘴裡飄著的果香——喝一口，你就知道。
                <span class="menu-intro__punch">幸福？有時候就這麼簡單。</span>
              </p>
            </div>
          </div>

          <div class="menu-carousel-wrap" id="menu-carousel-wrap">
            <div class="menu-carousel-viewport" id="menu-carousel-viewport">
              <div class="menu-carousel-track" id="menu-carousel-track">
                {
                  menuItems.map((item, i) => (
                    <article
                      class="menu-carousel-slide modern-card"
                      data-slide-index={i}
                    >
                      <div class="menu-slide-image relative aspect-[4/3] overflow-hidden border-b border-gray-100/80 sm:aspect-[5/4]">
                        <img
                          src={item.image ?? imgMenuProduct}
