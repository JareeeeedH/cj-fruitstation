---
import "../styles/global.css";
import StoreContact from "../components/StoreContact.astro";
import SiteFooter from "../components/SiteFooter.astro";
import {
  brandName,
  brandSlogan,
  brandTagline,
  facebookUrl,
  googleMapsBusinessUrl,
  instagramUrl,
  shortBrandName,
} from "../data/store.ts";

const imgHero = "/juice-1.webp";
const imgStorefront = "/homePhoto-3.webp";
const imgMenuProduct = "/juice-2.webp";

const siteUrl = Astro.site?.href ?? Astro.url.origin;
const ogImage = new URL(imgStorefront, siteUrl).href;

const siteTitle = `${shortBrandName}｜旗津果汁 · 現打現做`;
const siteDescription =
  `${shortBrandName}：中洲三路641，在地20餘年現打果汁。現點現打、真水果現場做。渡輪站步行約6分鐘、海科大斜對面。平日10:00–20:00；週末10:00–18:00（亦可能更早），0987-553-799。`;

const seoKeywords =
  "旗津必吃,旗津隱藏版美食,旗津果汁,旗津美食,旗津一日遊推薦,高雄現打果汁,旗津冰沙,旗津現打果汁,中洲三路,旗津渡輪站,海洋科技大學,木瓜牛奶,芒果冰沙";

const sameAs = [googleMapsBusinessUrl, facebookUrl, instagramUrl].filter(
  (url) => url.startsWith("http")
);

const heroPoints = [
  { mark: "👤", text: "當地居民與學生，每天來這補一杯。" },
  { mark: "✓", text: "渡輪站步行約 6 分鐘、海科大斜對面。" },
];

const ownerStories = [
  {
    title: "闆娘日常：跟果農較真",
    text: "雨季或耕作不好，果農常拿次級果來銷貨，還說打果汁沒差。闆娘不買帳，當場嗆：「你賣這什麼垃圾給我！」——為此沒少跟果農吵。",
  },
  {
    title: "闆娘堅持：塑化劑風波",
    text: "塑化劑風波那陣子，大家不敢喝手搖，反而來排現打果汁。闆娘一樣堅持現點現打、真水果——二十年來，就圖大家喝得安心、健康。",
  },
];

const menuItems = [
  {
    name: "石蓮花奇異果",
    nameEn: "Cactus Pear & Kiwi",
    image: "/menu-cactus-kiwi.webp",
    tag: "招牌推薦",
