    taste: { sour: 58, sweet: 42 },
  },
  {
    name: "蔓越莓汁",
    nameEn: "Antioxidant Cranberry",
    image: "/menu-cranberry.webp",
    tag: "人氣必點",
    tagColor: "bg-mint-500",
