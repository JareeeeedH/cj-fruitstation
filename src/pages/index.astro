      type="button"
      id="back-to-top"
      class="back-to-top"
      aria-label="回到頁面頂部"
      title="回到頁面頂部"
      hidden
    >
      <svg class="back-to-top__icon" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <script>
      // Back to top
      const backToTop = document.getElementById("back-to-top");
      const backToTopThreshold = 400;

      function updateBackToTop() {
        if (!backToTop) return;
        const show = window.scrollY > backToTopThreshold;
        backToTop.hidden = !show;
        backToTop.classList.toggle("back-to-top--visible", show);
      }

      updateBackToTop();
      window.addEventListener("scroll", updateBackToTop, { passive: true });

      backToTop?.addEventListener("click", () => {
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
      });

      // Menu carousel (mobile: 1 slide · desktop: 3 columns)
      const menuTrack = document.getElementById("menu-carousel-track");
      const menuViewport = document.getElementById("menu-carousel-viewport");
      const menuSlides = menuTrack?.querySelectorAll<HTMLElement>(".menu-carousel-slide");
      const menuDots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");
      let menuSlideIndex = 0;

      const desktopCarouselMq = window.matchMedia("(min-width: 1024px)");

      function getSlidesPerView() {
        return desktopCarouselMq.matches ? 3 : 1;
      }

      function updateActiveDots() {
        menuDots.forEach((dot, i) => {
          const active = i === menuSlideIndex;
          dot.classList.toggle("is-active", active);
          dot.setAttribute("aria-selected", active ? "true" : "false");
        });
      }

      function syncMenuIndexFromScroll() {
        if (!menuSlides?.length || !menuTrack) return;
        const trackRect = menuTrack.getBoundingClientRect();
        const trackAnchor = trackRect.left + trackRect.width * 0.2;
        let closestIdx = menuSlideIndex;
        let closestDist = Infinity;

        menuSlides.forEach((slide, i) => {
          const rect = slide.getBoundingClientRect();
          const slideAnchor = rect.left;
          const dist = Math.abs(slideAnchor - trackAnchor);
          if (dist < closestDist) {
            closestDist = dist;
            closestIdx = i;
          }
        });

        menuSlideIndex = closestIdx;
      }

      function goToMenuSlide(index: number) {
        if (!menuSlides?.length || !menuTrack) return;
        const maxIndex = menuSlides.length - 1;
        const perView = getSlidesPerView();
        const maxStart = Math.max(0, maxIndex - perView + 1);
        menuSlideIndex = Math.max(0, Math.min(index, maxStart));

        const target = menuSlides[menuSlideIndex];
        const inline = desktopCarouselMq.matches ? "start" : "center";

        target?.scrollIntoView({
          behavior: "smooth",
          inline,
          block: "nearest",
        });
        updateActiveDots();
      }

      function stepMenuCarousel(direction: number) {
        goToMenuSlide(menuSlideIndex + direction * getSlidesPerView());
      }

      document.getElementById("menu-carousel-prev")?.addEventListener("click", () => {
        stepMenuCarousel(-1);
      });
      document.getElementById("menu-carousel-next")?.addEventListener("click", () => {
        stepMenuCarousel(1);
      });
      menuDots.forEach((dot, i) => {
        dot.addEventListener("click", () => goToMenuSlide(i));
      });

      desktopCarouselMq.addEventListener("change", () => goToMenuSlide(menuSlideIndex));

      if (menuTrack && menuSlides?.length && "IntersectionObserver" in window) {
        const slideObserver = new IntersectionObserver(
          (entries) => {
            let bestIdx = menuSlideIndex;
            let bestRatio = 0;
            entries.forEach((entry) => {
              if (entry.isIntersecting && entry.intersectionRatio > bestRatio) {
                bestRatio = entry.intersectionRatio;
                const idx = Number((entry.target as HTMLElement).dataset.slideIndex);
                if (!Number.isNaN(idx)) bestIdx = idx;
              }
            });
            if (bestRatio > 0.4 && bestIdx !== menuSlideIndex) {
              menuSlideIndex = bestIdx;
              updateActiveDots();
            }
          },
          { root: menuViewport ?? menuTrack, threshold: [0.4, 0.55, 0.7] }
        );
        menuSlides.forEach((slide) => slideObserver.observe(slide));
      }

      // Desktop: drag within viewport to scroll carousel
      if (menuViewport && menuTrack) {
        let isPointerDragging = false;
        let pointerStartX = 0;
        let pointerStartScroll = 0;
        let pointerDidDrag = false;

        menuViewport.addEventListener("mousedown", (event) => {
          if (!desktopCarouselMq.matches || event.button !== 0) return;
          const target = event.target as HTMLElement;
          if (target.closest("button, a")) return;

          isPointerDragging = true;
          pointerDidDrag = false;
          pointerStartX = event.pageX;
          pointerStartScroll = menuTrack.scrollLeft;
          menuViewport.classList.add("menu-carousel-viewport--dragging");
        });

        window.addEventListener("mousemove", (event) => {
          if (!isPointerDragging) return;
          const delta = event.pageX - pointerStartX;
          if (Math.abs(delta) > 4) pointerDidDrag = true;
          menuTrack.scrollLeft = pointerStartScroll - delta;
        });

        window.addEventListener("mouseup", (event) => {
          if (!isPointerDragging) return;
          isPointerDragging = false;
          menuViewport.classList.remove("menu-carousel-viewport--dragging");

          if (!desktopCarouselMq.matches || !pointerDidDrag) return;

          const delta = event.pageX - pointerStartX;
          syncMenuIndexFromScroll();

          if (Math.abs(delta) > 48) {
            goToMenuSlide(menuSlideIndex + (delta > 0 ? -1 : 1));
          } else {
            goToMenuSlide(menuSlideIndex);
          }
        });

        menuViewport.addEventListener(
          "click",
          (event) => {
            if (!pointerDidDrag) return;
            event.preventDefault();
            event.stopPropagation();
            pointerDidDrag = false;
          },
          true,
        );
      }

    </script>
  </body>
</html>
