---
import "../styles/global.css";

const siteTitle = "旗津必吃 | 在地鮮果汁冰沙吧 — 高雄現打果汁老店";
const siteDescription =
  "旗津必吃鮮果汁冰沙吧，在地20年老店。走旗津一日遊觀光路線會經過，但很多遊客壓根不知道。中洲三路641，距離渡輪站步行約3分鐘。真水果現點現打，旗津美食與在地內行才知道的好味道。";

const menuItems = [
  {
    name: "木瓜牛奶",
    nameEn: "Papaya Milk",
    price: 65,
    tag: "20年經典",
    tagColor: "bg-mango-500",
    desc: "土木瓜現打，濃稠順口、不死甜。旗津當地居民喝了二十年的那杯，老客人不換別家。",
  },
  {
    name: "芒果冰沙",
    nameEn: "Mango Smoothie",
    price: 70,
    tag: "夏日招牌",
    tagColor: "bg-mint-500",
    desc: "愛文芒果打冰沙，走完整條旗津老街，來這杯最剛好。",
  },
  {
    name: "西瓜汁",
    nameEn: "Watermelon Juice",
    price: 55,
    tag: "造船藍領最愛",
    tagColor: "bg-mango-400",
    desc: "大顆西瓜現榨，造船廠下班的藍領大哥最愛。扛完一上午，來這杯補水補勁，不加水騙人。",
  },
  {
    name: "綜合果汁",
    nameEn: "Mixed Fresh Juice",
    price: 60,
    tag: "看老闆心情",
    tagColor: "bg-mint-400",
    desc: "當天市場有什麼好貨就打什麼，每次來可能不一樣，但杯杯真材實料。",
  },
  {
    name: "芭樂汁",
    nameEn: "Guava Juice",
    price: 55,
    tag: "南部味",
    tagColor: "bg-mint-600",
    desc: "紅心芭樂現榨，酸甘帶勁。海科大學生下課常來買——旗津學子固定的營養補充站。",
  },
  {
    name: "鳳梨冰沙",
    nameEn: "Pineapple Smoothie",
    price: 65,
    tag: "20年經典",
    tagColor: "bg-mango-500",
    desc: "金鑽鳳梨打冰沙，酸甜剛好。旗津夏天扛太陽，這杯最解。",
  },
];

const attractions = [
  {
    name: "高雄燈塔",
    emoji: "🗼",
    keywords: "旗津一日遊推薦 · 解渴補給站",
    desc: "爬完燈塔下來，海風吹得口很渴？<strong>旗津一日遊推薦</strong>路線其實會經過這段，但很多人走過去不知道。順路買杯<strong>高雄現打果汁</strong>補水，內行才會停。",
  },
  {
    name: "旗津老街",
    emoji: "🏮",
    keywords: "旗津美食 · 旗津必吃",
    desc: "老街<strong>旗津美食</strong>吃一圈，嘴巴鹹了、走累了，來杯現打果汁剛好。觀光動線會經過，但攻略很少寫——旗津當地居民天天買，<strong>在地內行才知道</strong>的<strong>旗津必吃</strong>。",
  },
  {
    name: "彩虹教堂",
    emoji: "⛪",
    keywords: "旗津一日遊推薦 · 打卡後歇腳",
    desc: "彩虹教堂拍完照，太陽正猛。這段<strong>旗津一日遊推薦</strong>動線你會走過，但不一定會注意到我們——買杯芒果冰沙邊走邊喝，比便利商店瓶裝的實在。",
  },
  {
    name: "星空隧道",
    emoji: "✨",
    keywords: "旗津必吃 · 海濱散步",
    desc: "穿越隧道吹完全身海風，這時候一杯現榨西瓜汁最對味。走觀光路線會經過，但你可能就這樣走過去了——造船藍領、海科大的內行才會停，這才是<strong>旗津必吃</strong>。",
  },
  {
    name: "風車公園",
    emoji: "🌬️",
    keywords: "旗津美食 · 親子同遊",
    desc: "帶小孩跑風車公園，大人小孩都渴。綜合果汁現打現做，真水果給孩子喝也安心。旗津親子<strong>旗津美食</strong>行程，這杯可以排進去。",
  },
  {
    name: "旗後砲台",
    emoji: "🏰",
    keywords: "旗津一日遊推薦 · 走累就買",
    desc: "砲台上下爬，腿酸口也乾。走下來買杯<strong>高雄現打果汁</strong>歇個腳，20年老店就在附近。很多<strong>旗津一日遊推薦</strong>攻略後來才補寫：路過不知道，走了才後悔沒買。",
  },
];

const articles = [
  {
    title: "為什麼我們只用全熟水果？",
    titleEn: "Why we only use fully ripened fruits",
    date: "2025-03-15",
    readTime: "3 分鐘",
    excerpt:
      "水果沒熟就打，味道淡、還得加糖遮。我們寧可少賣幾杯，也要等它熟透了才進店。你喝到的就是水果本身，不多騙一口。",
    category: "老闆這樣說",
  },
  {
    title: "旗津夏天怎麼解渴才實在？",
    titleEn: "Beat the heat: why fresh juice beats bottled drinks",
    date: "2025-04-02",
    readTime: "4 分鐘",
    excerpt:
      "便利商店冰櫃一排排，但造船廠幹活的、海科大晚課後的，最知道現打果汁才解得了渴。維生素C、鉀，現場現做才留得住——旗津人的營養補充，不必花大錢。",
    category: "解渴指南",
  },
  {
    title: "20年旗津老店，挑水果就這幾條",
    titleEn: "Two decades of fruit selection wisdom",
    date: "2025-05-10",
    readTime: "5 分鐘",
    excerpt:
      "天亮去市場，摸熟度、看當季。20年下來就一套：好果才打、你點了才做。走旗津一日遊路線會經過，但遊客常常不知道；旗津當地居民跟造船藍領不用問，內行都懂這間。",
    category: "品牌故事",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "JuiceBar",
  name: "旗津必吃 | 在地鮮果汁冰沙吧",
  description: siteDescription,
  address: {
    "@type": "PostalAddress",
    streetAddress: "中洲三路641",
    addressLocality: "旗津區",
    addressRegion: "高雄市",
    postalCode: "805",
    addressCountry: "TW",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 22.6128,
    longitude: 120.2842,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "09:00",
      closes: "20:00",
    },
  ],
  priceRange: "$$",
  servesCuisine: "Fresh Juice, Smoothie",
  url: Astro.url.origin,
};
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta
      name="keywords"
      content="旗津必吃,旗津美食,旗津一日遊推薦,高雄現打果汁,旗津果汁,旗津冰沙,高雄旗津,中洲三路,旗津渡輪站,現打果汁,木瓜牛奶,芒果冰沙"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="旗津必吃 | 在地鮮果汁冰沙吧" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="overflow-x-hidden text-gray-800 antialiased">
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- ========== Header / Nav ========== -->
