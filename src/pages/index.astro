    taste: { sour: 72, sweet: 28 },
  },
  {
    name: "芒果冰沙",
    nameEn: "Mango Smoothie",
    image: "/menu-mango-smoothie.webp",
    tag: "20年經典",
    tagColor: "bg-mango-400",
    intro: "濃郁香甜沁涼順口，不膩解熱，老街逛完最想來一杯。",
    taste: { sour: 18, sweet: 82 },
  },
  {
    name: "紅龍果牛奶",
    nameEn: "Dragon Fruit Milk",
    image: "/menu-dragon-fruit-milk.webp",
    tag: "在地最愛",
    tagColor: "bg-mint-600",
    intro: "甜菜紅素抗氧化，粉嫩順口綿密，午後補元氣好選擇。",
    taste: { sour: 22, sweet: 78 },
  },
  {
    name: "綜合蔬果汁",
    nameEn: "Mixed Veggie Juice",
    image: "/menu-mixed-veggie.webp",
    tag: "健康首選",
    tagColor: "bg-mint-400",
    intro: "當季現榨高膳食纖維，清甜不生澀，顧健康內行都愛點。",
    taste: { sour: 45, sweet: 55 },
  },
  {
    name: "經典木瓜牛奶",
    nameEn: "Classic Papaya Milk",
    image: "/menu-papaya-milk.webp",
    tag: "20年經典",
    tagColor: "bg-mango-500",
    intro: "濃稠順口不死甜，天然酵素助消化，老客二十年不離手。",
    taste: { sour: 12, sweet: 88 },
  },
  {
    name: "葡萄多多",
    nameEn: "Grape Duoduo",
    image: "/menu-grape-duoduo.webp",
    tag: "人氣必點",
    tagColor: "bg-mint-500",
    intro: "酸甜微氣泡感，沁涼解暑順口，夏天走熱最想再來杯。",
    taste: { sour: 42, sweet: 58 },
  },
  {
    name: "綠豆沙牛奶",
    nameEn: "Mung Bean Milk",
    image: "/menu-mung-bean-milk.webp",
    tag: "南部經典",
    tagColor: "bg-mango-400",
    intro: "綿密砂感消暑退火，順口不膩，南部老客說最實在的一杯。",
    taste: { sour: 15, sweet: 85 },
  },
];

const attractions = [
  {
    name: "旗津天后宮",
    emoji: "🛕",
    keywords: "旗津一日遊推薦 · 廟前老街",
    desc: "拜完媽祖、逛廟前路老街，海鮮小吃一輪下來嘴巴又鹹又渴。<strong>旗津一日遊推薦</strong>動線多半會經過這帶，順路來杯現打果汁解膩，比便利商店瓶裝的實在。",
  },
  {
    name: "高雄燈塔",
    emoji: "🗼",
    keywords: "旗津一日遊推薦 · 解渴補給站",
    desc: "爬完燈塔下來，海風吹得口很渴？<strong>旗津一日遊推薦</strong>路線其實會經過這段，但很多人走過去不知道。順路買杯<strong>高雄現打果汁</strong>補水，內行才會停。",
  },
  {
    name: "旗津老街",
    emoji: "🏮",
    keywords: "旗津美食 · 旗津蔬果茶飲",
    desc: `老街<strong>旗津美食</strong>、<strong>旗津小吃</strong>吃一圈，吃飽後很適合來杯現打果汁解膩。嘴巴鹹了、走累了也剛好——觀光動線會經過，但攻略很少寫，<strong>在地內行才知道</strong>的<strong>${brandName}</strong>。`,
  },
  {
    name: "彩虹教堂",
    emoji: "⛪",
    keywords: "旗津一日遊推薦 · 打卡後歇腳",
    desc: "彩虹教堂拍完照，太陽正猛。這段<strong>旗津一日遊推薦</strong>動線你會走過，但不一定會注意到我們——買杯芒果冰沙邊走邊喝，比便利商店瓶裝的實在。",
  },
  {
    name: "風車公園",
    emoji: "🌬️",
    keywords: "旗津美食 · 親子同遊",
    desc: "帶小孩跑風車公園，大人小孩都渴。綜合果汁現打現做，真水果給孩子喝也安心。旗津親子<strong>旗津美食</strong>行程，這杯可以排進去。",
  },
  {
    name: "旗後砲台",
    emoji: "🏰",
    keywords: "旗津一日遊推薦 · 走累就買",
    desc: "砲台上下爬，腿酸口也乾。走下來買杯<strong>高雄現打果汁</strong>歇個腳，20年老店就在附近。很多<strong>旗津一日遊推薦</strong>攻略後來才補寫：路過不知道，走了才後悔沒買。",
  },
];

const articles = [
  {
    title: "高雄「鳳荔季」開跑　行銷在地農特產",
    source: "中央社 CNA",
    date: "2026-05-30",
    excerpt:
      "2026 高雄鳳荔季於大樹區農會姑山倉庫登場，推廣玉荷包荔枝、金鑽鳳梨；市府指大樹有「玉荷包故鄉」美名，金鑽鳳梨產期僅約 2 至 3 週，把握當季選購。",
    url: "https://www.cna.com.tw/news/aloc/202605300111.aspx",
    category: "高雄農業",
  },
  {
    title: "5月起月月有水果　高雄夏祭新鮮市開跑",
    source: "自由時報",
    date: "2026-05-27",
    excerpt:
      "2026 高雄夏祭新鮮市 5 月至 9 月串聯鳳荔、金煌芒果、龍眼蜂蜜、香蕉等活動；並宣布學校營養午餐將採用高雄在地水果，縮短碳足跡、推動食農教育。",
    url: "https://news.ltn.com.tw/news/life/breakingnews/5451091",
    category: "產季活動",
  },
  {
    title: "高溫少雨催熟　玉荷包荔枝提早上市",
    source: "自由時報",
    date: "2026-05-21",
    excerpt:
      "大樹玉荷包因高溫少雨提早進入盛產，產季可能較往年提早結束；高雄玉荷包種植面積與產量全國第一，5 月 30、31 日鳳荔季活動於姑山倉庫登場。",
    url: "https://news.ltn.com.tw/news/life/breakingnews/5445032",
    category: "產季報導",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "JuiceBar",
  name: shortBrandName,
  alternateName: [brandName, "旗津果汁", "旗津現打果汁"],
  description: siteDescription,
  image: ogImage,
  address: {
    "@type": "PostalAddress",
    streetAddress: "中洲三路641",
    addressLocality: "旗津區",
    addressRegion: "高雄市",
    postalCode: "805",
    addressCountry: "TW",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 22.6128,
    longitude: 120.2842,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "10:00",
      closes: "20:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday", "Sunday"],
      opens: "10:00",
      closes: "18:00",
    },
  ],
  telephone: "+886987553799",
  priceRange: "$$",
  servesCuisine: "Fresh Juice, Smoothie",
  url: siteUrl,
  ...(sameAs.length > 0 ? { sameAs } : {}),
};

---

<!doctype html>
<html lang="zh-Hant">
	<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta name="keywords" content={seoKeywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={new URL(Astro.url.pathname, siteUrl).href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content={brandName} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${shortBrandName} — 旗津現打果汁`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>

  <body class="overflow-x-hidden text-gray-800 antialiased">
    <!-- ========== Header / Nav ========== -->
    <header class="glass-nav">
      <nav
        class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6"
        aria-label="主要導覽"
      >
        <a href="/" class="group flex min-w-0 items-center gap-2">
          <span
            class="logo-glow flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded-xl"
            aria-hidden="true"
          >
            <img src="/favicon.svg" alt="" class="nav-logo" width="28" height="28" />
          </span>
          <div class="hidden min-w-0 leading-tight md:block">
            <span class="block text-sm font-extrabold text-mango-600 lg:text-base">
              {brandName}
            </span>
            <span class="block text-xs font-medium text-gray-500">
              {brandTagline}
            </span>
          </div>
          <span class="truncate text-sm font-extrabold text-mango-600 md:hidden">
            {brandName}
          </span>
        </a>

        <div class="flex shrink-0 items-center gap-2">
          <ul class="hidden items-center gap-1 md:order-1 md:flex">
            <li>
              <a
                href="#about"
                class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
              >關於蔬果茶飲</a>
            </li>
            <li>
              <a
                href="#location"
                class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
              >店面位置</a>
            </li>
            <li>
              <a
                href="#guide"
                class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
              >觀光導覽</a>
            </li>
            <li>
              <a
                href="#reading"
                class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
              >水果讀物</a>
            </li>
          </ul>

          <a href="#menu" class="nav-cta order-1 md:order-2">
            推薦飲品
          </a>

          <button
            type="button"
            id="nav-menu-toggle"
            class="nav-menu-btn order-2 md:hidden"
            aria-expanded="false"
            aria-controls="mobile-nav-panel"
            aria-label="開啟選單"
          >
            <svg class="nav-menu-btn__icon nav-menu-btn__icon--open" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="nav-menu-btn__icon nav-menu-btn__icon--close" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </nav>

      <div id="mobile-nav-panel" class="mobile-nav-panel md:hidden" hidden>
        <ul class="mobile-nav-panel__list">
          <li><a href="#about" class="mobile-nav-panel__link">關於蔬果茶飲</a></li>
          <li><a href="#location" class="mobile-nav-panel__link">店面位置</a></li>
          <li><a href="#guide" class="mobile-nav-panel__link">觀光導覽</a></li>
          <li><a href="#reading" class="mobile-nav-panel__link">水果讀物</a></li>
        </ul>
      </div>
    </header>
    <div class="nav-spacer" aria-hidden="true"></div>

    <main>
      <!-- ========== Hero ========== -->
      <section
        class="hero-mesh relative overflow-hidden"
        aria-label="首頁橫幅"
      >
        <!-- Aurora + bubbles -->
        <div class="hero-aurora" aria-hidden="true"></div>
        <div class="bubble-field absolute inset-0" aria-hidden="true">
          <span class="bubble bubble--mango" style="--dur:9s;--delay:0s;--opacity:0.5;width:88px;height:88px;top:12%;left:6%;"></span>
          <span class="bubble bubble--mint" style="--dur:11s;--delay:1s;--opacity:0.45;width:56px;height:56px;top:28%;left:18%;"></span>
          <span class="bubble" style="--dur:8s;--delay:2s;--opacity:0.4;width:120px;height:120px;top:55%;left:4%;"></span>
          <span class="bubble bubble--mango" style="--dur:10s;--delay:0.5s;--opacity:0.55;width:72px;height:72px;top:18%;right:12%;"></span>
          <span class="bubble bubble--mint" style="--dur:12s;--delay:1.5s;--opacity:0.42;width:96px;height:96px;top:62%;right:8%;"></span>
          <span class="bubble" style="--dur:7s;--delay:3s;--opacity:0.35;width:44px;height:44px;top:78%;left:42%;"></span>
          <span class="bubble bubble--mango" style="--dur:9s;--delay:2.5s;--opacity:0.38;width:64px;height:64px;top:8%;left:48%;"></span>
        </div>

        <div class="hero-inner relative mx-auto max-w-6xl px-4 sm:px-6">
          <div class="hero-grid lg:grid-cols-2">
            <div class="hero-grid__media">
              <div class="hero-media-frame relative aspect-[4/3] overflow-hidden sm:aspect-[5/4] lg:rounded-3xl lg:shadow-lg lg:shadow-mango-500/10 lg:ring-1 lg:ring-black/5">
                <img
                  src={imgHero}
                  alt={`${brandName}現打鮮果汁`}
                  class="hero-media-frame__photo h-full w-full object-cover"
                  width={800}
                  height={600}
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            </div>

            <div class="hero-grid__content">
              <span
                class="tech-pill mb-3 inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-semibold text-mint-600 sm:mb-4"
              >
                🌴 在地經營20餘年 · 內行人的營養補充站
              </span>
              <h1 class="hero-headline">
                <span class="hero-brand-wrap">
                  <strong class="hero-brand-title">{brandName}</strong>
                  <span class="hero-brand-accent" aria-hidden="true"></span>
                </span>
                <span class="gradient-heading hero-tagline">{brandTagline}</span>
              </h1>
              <ul class="hero-points max-w-lg" aria-label="店家特色">
                {
                  heroPoints.map((point) => (
                    <li class="hero-points__item">
                      <span class="hero-points__mark" aria-hidden="true">{point.mark}</span>
                      <span class="hero-points__text">{point.text}</span>
                    </li>
                  ))
                }
              </ul>
              <div class="hero-actions mt-6 flex flex-wrap gap-3 sm:mt-8">
                <a href="#menu" class="hero-btn hero-btn--primary">
                  <span class="hero-btn__glyph" aria-hidden="true">
                    <svg class="hero-btn__juice" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 4h8l-1 14H9L8 4z" />
                      <path stroke-linecap="round" d="M9 4c0-1.5 1.5-2 3-2s3 .5 3 2" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v5" />
                    </svg>
                  </span>
                  <span class="hero-btn__label">看推薦飲品</span>
                  <svg class="hero-btn__chev" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <a href="#location" class="hero-btn hero-btn--route">
                  <span class="hero-btn__glyph hero-btn__glyph--mint" aria-hidden="true">
                    <svg class="hero-btn__pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21s7-4.35 7-10a7 7 0 10-14 0c0 5.65 7 10 7 10z" />
                      <circle cx="12" cy="11" r="2.5" fill="currentColor" stroke="none" />
                    </svg>
                  </span>
                  <span class="hero-btn__label">店怎麼走</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ========== 推薦飲品（banner 下方） ========== -->
      <section id="menu" class="section-bg section-bg-menu scroll-mt-20 section-after-hero">
        <div class="tech-grid-layer" aria-hidden="true"></div>
        <div class="section-inner mx-auto max-w-6xl px-4 sm:px-6">
          <div class="mb-6 text-left">
            <span class="section-badge tech-badge">Fresh Menu</span>
            <h2 class="section-title-tech mt-3">推薦飲品</h2>
            <div class="section-accent-line"></div>
            <div class="menu-intro mt-3 max-w-2xl">
