---
import "../styles/global.css";

const imgHero = "/juice-1.png";
const imgStorefront = "/homePhoto-3.jpg";
const imgMenuProduct = "/juice-2.png";

const siteTitle = "旗津必吃 | 在地鮮果汁冰沙吧 — 高雄現打果汁老店";
const siteDescription =
  "旗津必吃鮮果汁冰沙吧，在地經營20餘年、用料實在。當地居民、造船廠藍領、海洋科技大學學生每日固定的營養補給站。走旗津一日遊會經過，但攻略很少寫——中洲三路641，渡輪站步行約6分鐘。";

const menuItems = [
  {
    name: "高機能石蓮花奇異果",
    nameEn: "Cactus Pear & Kiwi",
    price: 85,
    tag: "招牌推薦",
    tagColor: "bg-mango-500",
    intro: "石蓮花配黃金奇異果，清爽高機能，走累曬後最該補的一杯。",
  },
  {
    name: "抗氧化蔓越莓",
    nameEn: "Antioxidant Cranberry",
    price: 80,
    tag: "老店研發",
    tagColor: "bg-mint-500",
    intro: "蔓越莓現榨酸甜，抗氧化系飲品，內行女生常來的秘密杯。",
  },
  {
    name: "愛文芒果冰沙",
    nameEn: "Irwin Mango Smoothie",
    price: 75,
    tag: "20年經典",
    tagColor: "bg-mango-400",
    intro: "愛文芒果現打冰沙，濃郁不膩，旗津老街走完最對味。",
  },
  {
    name: "紅龍果牛奶",
    nameEn: "Dragon Fruit Milk",
    price: 70,
    tag: "在地最愛",
    tagColor: "bg-mint-600",
    intro: "紅龍果撞鮮奶，粉嫩順口，居民跟學生午後固定點。",
  },
  {
    name: "綜合蔬果汁",
    nameEn: "Mixed Veggie Juice",
    price: 65,
    tag: "健康首選",
    tagColor: "bg-mint-400",
    intro: "當季蔬菜現榨，清甜不生澀，想顧健康的人內行都喝。",
  },
  {
    name: "經典木瓜牛奶",
    nameEn: "Classic Papaya Milk",
    price: 65,
    tag: "20年經典",
    tagColor: "bg-mango-500",
    intro: "土木瓜現打配鮮奶，濃稠順口不死甜，老客人喝了二十年。",
  },
  {
    name: "葡萄汁多多",
    nameEn: "Grape Duoduo",
    price: 70,
    tag: "人氣必點",
    tagColor: "bg-mint-500",
    intro: "葡萄現榨加多多，酸甜帶氣泡感，夏天旗津最想再來一杯。",
  },
  {
    name: "綠豆沙牛奶",
    nameEn: "Mung Bean Milk",
    price: 65,
    tag: "南部經典",
    tagColor: "bg-mango-400",
    intro: "綠豆熬香撞鮮奶，消暑順口不膩，老客人說這杯最實在。",
  },
];

const attractions = [
  {
    name: "高雄燈塔",
    emoji: "🗼",
    keywords: "旗津一日遊推薦 · 解渴補給站",
    desc: "爬完燈塔下來，海風吹得口很渴？<strong>旗津一日遊推薦</strong>路線其實會經過這段，但很多人走過去不知道。順路買杯<strong>高雄現打果汁</strong>補水，內行才會停。",
  },
  {
    name: "旗津老街",
    emoji: "🏮",
    keywords: "旗津美食 · 旗津必吃",
    desc: "老街<strong>旗津美食</strong>吃一圈，嘴巴鹹了、走累了，來杯現打果汁剛好。觀光動線會經過，但攻略很少寫——旗津當地居民天天買，<strong>在地內行才知道</strong>的<strong>旗津必吃</strong>。",
  },
  {
    name: "彩虹教堂",
    emoji: "⛪",
    keywords: "旗津一日遊推薦 · 打卡後歇腳",
    desc: "彩虹教堂拍完照，太陽正猛。這段<strong>旗津一日遊推薦</strong>動線你會走過，但不一定會注意到我們——買杯芒果冰沙邊走邊喝，比便利商店瓶裝的實在。",
  },
  {
    name: "星空隧道",
    emoji: "✨",
    keywords: "旗津必吃 · 海濱散步",
    desc: "穿越隧道吹完全身海風，這時候一杯現榨果汁最對味。走觀光路線會經過，但你可能就這樣走過去了——造船廠藍領、海洋科技大學學生的內行才會停。",
  },
  {
    name: "風車公園",
    emoji: "🌬️",
    keywords: "旗津美食 · 親子同遊",
    desc: "帶小孩跑風車公園，大人小孩都渴。綜合果汁現打現做，真水果給孩子喝也安心。旗津親子<strong>旗津美食</strong>行程，這杯可以排進去。",
  },
  {
    name: "旗後砲台",
    emoji: "🏰",
    keywords: "旗津一日遊推薦 · 走累就買",
    desc: "砲台上下爬，腿酸口也乾。走下來買杯<strong>高雄現打果汁</strong>歇個腳，20年老店就在附近。很多<strong>旗津一日遊推薦</strong>攻略後來才補寫：路過不知道，走了才後悔沒買。",
  },
];

const articles = [
  {
    title: "為什麼我們只用全熟水果？",
    titleEn: "Why we only use fully ripened fruits",
    date: "2025-03-15",
    readTime: "3 分鐘",
    excerpt:
      "水果沒熟就打，味道淡、還得加糖遮。我們寧可少賣幾杯，也要等它熟透了才進店。你喝到的就是水果本身，不多騙一口。",
    category: "老闆這樣說",
  },
  {
    title: "旗津夏天怎麼解渴才實在？",
    titleEn: "Beat the heat: why fresh juice beats bottled drinks",
    date: "2025-04-02",
    readTime: "4 分鐘",
    excerpt:
      "便利商店冰櫃一排排，但造船廠幹活的、海洋科技大學晚課後的，最知道現打果汁才解得了渴。維生素C、鉀，現場現做才留得住——旗津人的營養補充，不必花大錢。",
    category: "解渴指南",
  },
  {
    title: "20年旗津老店，挑水果就這幾條",
    titleEn: "Two decades of fruit selection wisdom",
    date: "2025-05-10",
    readTime: "5 分鐘",
    excerpt:
      "天亮去市場，摸熟度、看當季。20餘年下來就一套：好果才打、你點了才做。走旗津一日遊路線會經過，但攻略很少寫——當地居民、造船廠藍領、海洋科技大學學生，內行都懂這間。",
    category: "品牌故事",
  },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "JuiceBar",
  name: "旗津必吃 | 在地鮮果汁冰沙吧",
  description: siteDescription,
  address: {
    "@type": "PostalAddress",
    streetAddress: "中洲三路641",
    addressLocality: "旗津區",
    addressRegion: "高雄市",
    postalCode: "805",
    addressCountry: "TW",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 22.6128,
    longitude: 120.2842,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "09:00",
      closes: "20:00",
    },
  ],
  priceRange: "$$",
  servesCuisine: "Fresh Juice, Smoothie",
  url: Astro.url.origin,
};
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <meta
      name="keywords"
      content="旗津必吃,旗津美食,旗津一日遊推薦,高雄現打果汁,旗津果汁,旗津冰沙,高雄旗津,中洲三路,旗津渡輪站,現打果汁,木瓜牛奶,芒果冰沙"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="旗津必吃 | 在地鮮果汁冰沙吧" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="overflow-x-hidden text-gray-800 antialiased">
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- ========== Header / Nav ========== -->
    <header class="glass-nav sticky top-0 z-40">
      <nav
        class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6"
        aria-label="主要導覽"
      >
        <a href="#" class="group flex items-center gap-2">
          <span
            class="logo-glow flex h-9 w-9 items-center justify-center rounded-xl text-lg text-white"
            aria-hidden="true"
          >🍊</span>
          <div class="leading-tight">
            <span class="block text-sm font-extrabold text-mango-600 sm:text-base">
              旗津必吃
            </span>
            <span class="block text-[10px] font-medium text-gray-500 sm:text-xs">
              在地鮮果汁冰沙吧
            </span>
          </div>
        </a>

        <ul class="hidden items-center gap-1 md:flex">
          <li>
            <a
              href="#about"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >關於我們</a>
          </li>
          <li>
            <a
              href="#menu"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >果汁好物</a>
          </li>
          <li>
            <a
              href="#guide"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >觀光導覽</a>
          </li>
          <li>
            <a
              href="#reading"
              class="nav-link-modern rounded-lg px-3 py-2 text-sm font-medium text-gray-600 hover:text-mango-600"
            >水果讀物</a>
          </li>
        </ul>

        <a
          href="#menu"
          class="btn-glow rounded-full bg-mango-500 px-4 py-2 text-xs font-bold text-white shadow-md shadow-mango-500/30 hover:bg-mango-600 sm:text-sm"
        >
          推薦飲品
        </a>
      </nav>

      <!-- Mobile nav -->
      <div class="border-t border-gray-100 md:hidden">
        <ul class="flex overflow-x-auto px-4 py-2 text-xs font-medium whitespace-nowrap">
          <li><a href="#about" class="mr-4 text-gray-600">關於我們</a></li>
          <li><a href="#menu" class="mr-4 text-gray-600">果汁好物</a></li>
          <li><a href="#guide" class="mr-4 text-gray-600">觀光導覽</a></li>
          <li><a href="#reading" class="text-gray-600">水果讀物</a></li>
        </ul>
      </div>
    </header>

    <main>
      <!-- ========== Hero ========== -->
      <section
        class="hero-mesh relative overflow-hidden"
        aria-label="首頁橫幅"
      >
        <!-- Aurora + bubbles -->
        <div class="hero-aurora" aria-hidden="true"></div>
        <div class="bubble-field absolute inset-0" aria-hidden="true">
          <span class="bubble bubble--mango" style="--dur:9s;--delay:0s;--opacity:0.5;width:88px;height:88px;top:12%;left:6%;"></span>
          <span class="bubble bubble--mint" style="--dur:11s;--delay:1s;--opacity:0.45;width:56px;height:56px;top:28%;left:18%;"></span>
          <span class="bubble" style="--dur:8s;--delay:2s;--opacity:0.4;width:120px;height:120px;top:55%;left:4%;"></span>
          <span class="bubble bubble--mango" style="--dur:10s;--delay:0.5s;--opacity:0.55;width:72px;height:72px;top:18%;right:12%;"></span>
          <span class="bubble bubble--mint" style="--dur:12s;--delay:1.5s;--opacity:0.42;width:96px;height:96px;top:62%;right:8%;"></span>
          <span class="bubble" style="--dur:7s;--delay:3s;--opacity:0.35;width:44px;height:44px;top:78%;left:42%;"></span>
          <span class="bubble bubble--mango" style="--dur:9s;--delay:2.5s;--opacity:0.38;width:64px;height:64px;top:8%;left:48%;"></span>
        </div>

        <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:py-28">
          <div class="grid items-center gap-10 lg:grid-cols-2">
            <div class="reveal-left">
              <span
                class="tech-pill mb-4 inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-xs font-semibold text-mint-600"
              >
                🌴 在地經營20餘年 · 內行人的營養補充站
              </span>
              <h1 class="text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl">
                <strong class="bg-gradient-to-r from-mango-600 to-mango-500 bg-clip-text text-transparent">旗津必吃</strong><br />
                <span class="gradient-heading">現打鮮果汁冰沙吧</span>
              </h1>
              <p class="mt-4 max-w-lg text-base leading-relaxed text-gray-600 sm:text-lg">
                在地經營、用料實在。當地居民、造船廠藍領、海洋科技大學學生，每天來這補一杯——觀光客多半不知道。
                走<strong>旗津一日遊</strong>路線其實會經過，但攻略很少寫；路過別就這樣走過去了。
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a
                  href="#menu"
                  class="btn-glow inline-flex items-center gap-2 rounded-full bg-mango-500 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-mango-500/30 hover:bg-mango-600"
                >
                  看推薦飲品
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </a>
                <a
                  href="#about"
                  class="inline-flex items-center gap-2 rounded-full border-2 border-gray-200 bg-white px-6 py-3 text-sm font-bold text-gray-700 transition hover:border-mint-400 hover:text-mint-600"
                >
                  店怎麼走
                </a>
              </div>
            </div>

            <div class="reveal-right">
              <div class="relative aspect-[4/3] overflow-hidden rounded-3xl shadow-lg shadow-mango-500/10 ring-1 ring-black/5">
                <img
                  src={imgHero}
                  alt="旗津必吃現打鮮果汁"
                  class="h-full w-full object-cover"
                  width={800}
                  height={600}
                  loading="eager"
                  fetchpriority="high"
                />
              </div>
            </div>
          </div>

          <a href="#about" class="scroll-hint mt-12 flex flex-col items-center gap-1 text-gray-400 no-underline" aria-label="往下滑動">
            <span class="text-[10px] font-medium tracking-widest uppercase">Scroll</span>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </section>

      <!-- ========== 1. About Us ========== -->
      <section id="about" class="section-bg section-bg-about scroll-mt-20 py-16 sm:py-24">
        <div class="tech-grid-layer" aria-hidden="true"></div>
        <div class="section-inner mx-auto max-w-6xl px-4 sm:px-6">
          <div class="reveal mb-12 text-left">
            <span class="section-badge tech-badge">About Us</span>
            <h2 class="section-title-tech mt-4">關於我們</h2>
            <div class="section-accent-line"></div>
            <p class="mt-4 max-w-2xl text-gray-600">
              在地經營20餘年，用料實在。當地居民、造船廠藍領、海洋科技大學學生，每天固定的營養補給站——觀光客多半不知道，但走旗津一日遊其實會經過。
            </p>
          </div>

          <div class="grid items-start gap-10 lg:grid-cols-2">
            <div class="reveal-left space-y-6" style="--reveal-delay:0.1s">
              <div class="glass-card rounded-3xl p-6 sm:p-8">
                <h3 class="text-xl font-bold text-gray-900">在地20餘年，規矩沒變過</h3>
                <p class="mt-3 leading-relaxed text-gray-600">
                  從開業到現在，就一套：好水果要熟、你點了才打、不多加糖騙人。
                  杯杯現做，喝到的就是水果本身，不是調味料調出來的。
                </p>
                <p class="mt-3 leading-relaxed text-gray-600">
                  除了經典產地鮮果，還有老店自己研發的頂級蔬果吧——品項多到你可能選擇困難，但內行都知道來這裡就對了。
                </p>
                <p class="mt-3 leading-relaxed text-gray-600">
                  中洲三路641，渡輪站步行約6分鐘、海洋科技大學斜對面走路約1分鐘。<strong>旗津一日遊</strong>攻略很少寫我們，但路線幾乎都會經過——當地居民、造船廠藍領、海洋科技大學學生，每天固定的營養補給站。
                </p>
                <ul class="mt-6 space-y-3">
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-mint-50 text-mint-500 text-xs">✓</span>
                    <span class="text-sm text-gray-700">天亮去市場挑當季水果，熟透了才進店</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-mint-50 text-mint-500 text-xs">✓</span>
                    <span class="text-sm text-gray-700">你點了才打，真材實料、不添加人工色素</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-mint-50 text-mint-500 text-xs">✓</span>
                    <span class="text-sm text-gray-700">到現場點、即打即出杯，杯杯現做不趕工</span>
                  </li>
                  <li class="flex items-start gap-3">
                    <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-mint-50 text-mint-500 text-xs">✓</span>
                    <span class="text-sm text-gray-700">LINE Pay、街口支付，結帳也快</span>
                  </li>
                </ul>
              </div>
            </div>

            <div class="reveal-right space-y-4" style="--reveal-delay:0.2s">
              <div class="relative aspect-[4/3] overflow-hidden rounded-3xl shadow-lg shadow-mint-500/10 ring-1 ring-black/5">
                <img
                  src={imgStorefront}
                  alt="旗津必吃店面外觀 · 高雄市旗津區中洲三路641"
                  class="h-full w-full object-cover"
                  width={800}
                  height={600}
                  loading="lazy"
                />
              </div>
            </div>
          </div>

          <!-- Google Map placeholder -->
          <div class="reveal mt-12" style="--reveal-delay:0.15s">
            <h3 class="mb-2 text-left text-lg font-bold text-gray-900">
              📍 店面位置
            </h3>
            <div class="section-accent-line mb-4"></div>
            <div class="location-info mb-4">
